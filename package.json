{
  "name": "nanoclaw",
  "version": "1.1.2",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "dev": "bun run src/index.ts",
    "auth": "bun run src/whatsapp-auth.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt \"src/**/*.ts\"",
    "format:check": "oxfmt --check \"src/**/*.ts\"",
    "setup": "bun run setup/index.ts",
    "test": "bun test src/ && bun test setup/ && bun test skills-engine/",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.39.0",
    "grammy": "^1.39.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "bun-types": "^1.2.0",
    "drizzle-kit": "^0.30.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.2"
  }
}
